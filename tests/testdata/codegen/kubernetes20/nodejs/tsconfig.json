{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "core/index.ts",
        "core/v1/configMap.ts",
        "core/v1/configMapList.ts",
        "core/v1/index.ts",
        "helm/index.ts",
        "helm/v3/index.ts",
        "helm/v3/release.ts",
        "index.ts",
        "provider.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts",
        "yaml/index.ts",
        "yaml/v2/configGroup.ts",
        "yaml/v2/index.ts"
    ]
}
