{
    "compilerOptions": {
        "outDir": "bin",
        "target": "ES2020",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "declaration": true,
        "sourceMap": true,
        "stripInternal": true,
        "experimentalDecorators": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true
    },
    "files": [
        "argFunction.ts",
        "index.ts",
        "otherResource.ts",
        "provider.ts",
        "resource.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
