{
  "$schema": "https://raw.githubusercontent.com/pulumi/pulumi/master/pkg/codegen/schema/pulumi.json",
  "name": "conflicta",
  "version": "1.0.0",
  "//": [
    "Pairs with conflictb: both packages define a module named \"mod\" so that generated Go",
    "programs using resources from both must disambiguate the conflicting imports.",
    "See https://github.com/pulumi/pulumi/issues/11176."
  ],
  "resources": {
    "conflicta:mod:Cluster": {
      "properties": {
        "arn": {
          "type": "string"
        }
      },
      "required": ["arn"],
      "type": "object"
    }
  },
  "language": {
    "go": {
      "importBasePath": "example.com/pulumi-conflicta/sdk/go/conflicta"
    }
  }
}
