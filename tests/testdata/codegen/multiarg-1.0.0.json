{
  "name": "multiarg",
  "version": "1.0.0",
  "meta": {
    "moduleFormat": "(.*)"
  },
  "config": {},
  "provider": {
    "type": "object"
  },
  "functions": {
    "multiarg:index:funcWithMultiArgs": {
      "description": "A function whose inputs are passed positionally.",
      "multiArgumentInputs": ["a", "b"],
      "inputs": {
        "type": "object",
        "properties": {
          "a": {
            "type": "string"
          },
          "b": {
            "type": "string"
          }
        },
        "required": ["a"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string"
          }
        },
        "required": ["result"]
      }
    }
  }
}
