{
  "$schema": "https://raw.githubusercontent.com/pulumi/pulumi/master/pkg/codegen/schema/pulumi.json",
  "name": "conflictb",
  "version": "1.0.0",
  "//": [
    "Pairs with conflicta: both packages define a module named \"mod\" so that generated Go",
    "programs using resources from both must disambiguate the conflicting imports.",
    "See https://github.com/pulumi/pulumi/issues/11176."
  ],
  "resources": {
    "conflictb:mod:Service": {
      "inputProperties": {
        "cluster": {
          "type": "string"
        }
      },
      "properties": {
        "cluster": {
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "language": {
    "go": {
      "importBasePath": "example.com/pulumi-conflictb/sdk/go/conflictb"
    }
  }
}
