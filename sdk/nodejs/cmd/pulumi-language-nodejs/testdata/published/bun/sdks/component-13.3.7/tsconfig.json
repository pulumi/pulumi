{
    "compilerOptions": {
        "outDir": "bin",
        "target": "ES2020",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "declaration": true,
        "sourceMap": true,
        "stripInternal": true,
        "experimentalDecorators": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true
    },
    "files": [
        "componentCallable.ts",
        "componentCustomRefInputOutput.ts",
        "componentCustomRefOutput.ts",
        "custom.ts",
        "index.ts",
        "provider.ts",
        "utilities.ts"
    ]
}
