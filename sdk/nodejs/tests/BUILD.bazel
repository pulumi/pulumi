load("@rules_shell//shell:sh_test.bzl", "sh_test")

# Node.js SDK tests
# These tests use the existing yarn/tsc/mocha toolchain via sh_test wrappers.
# They run in the source tree since they need node_modules and compiled output.

# Common data dependency for all unit test targets
_UNIT_DATA = [
    "//sdk/nodejs/cmd/pulumi-language-nodejs",
]

# Aggregate unit_tests target kept for backward compatibility with make build.
sh_test(
    name = "unit_tests",
    srcs = ["bazel_test_runner.sh"],
    args = ["unit"],
    data = _UNIT_DATA,
    size = "large",
    timeout = "long",
    tags = ["nodejs"],
)

# Split unit tests into smaller targets for parallel execution

sh_test(
    name = "unit_root_tests",
    srcs = ["bazel_test_runner.sh"],
    args = ["unit_root"],
    data = _UNIT_DATA,
    size = "medium",
    tags = ["nodejs"],
)

