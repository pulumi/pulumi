#!/usr/bin/env bash
#
# pulumi-pod — a `pulumi` stand-in for containerized (pod-mode) execution.
#
# It unconditionally bootstraps a pod and runs the given pulumi command inside the
# engine/CLI container — pulumi-pod *is* the OCI bootstrap, invoked intentionally,
# so there is no project-type sniffing or fall-through to a bare `pulumi`. Use it
# in place of `pulumi` for a containerized project (`pulumi-pod up`, `pulumi-pod
# preview`, `pulumi-pod stack output x`).
#
# It encapsulates the orchestration boilerplate that was previously hand-rolled in
# every smoke test: create a pod network, run the engine container on it with the
# docker socket + project (+ state + PULUMI_HOME) mounted and the PULUMI_POD_*
# contract set, run the command, then tear the pod down. Each invocation is one
# pulumi command in a fresh, ephemeral pod — the "self-contained execution unit"
# the design aims at, and the same shape a remote executor would run.
#
# Cost: every invocation stands up a container + network. For deploy commands
# (up/preview/destroy) that is inherent — they need the engine, providers, and
# program on a network. For read-only commands the network is unused overhead;
# acceptable for this MVP. The eventual local-dev optimization is a *persistent*
# pod session (a long-lived engine the wrapper attaches to, amortizing startup) —
# the design's tier-one inner-loop-latency concern, a separate feature.
#
# State persists across these ephemeral pods via mounts: PULUMI_POD_STATE_DIR holds
# the (file) backend, and PULUMI_POD_HOME holds PULUMI_HOME (login + stack
# selection), so a `stack select` sticks for a later `up` with no `--stack`.
#
# This is a prototype helper living alongside the smoke tests. The eventual home is
# the CLI itself (or an installed `pulumi-pod` on PATH); the design deliberately
# prefers this wrapper over having the CLI fork itself.
#
# Config via env (all optional):
#   PULUMI_POD_ENGINE_IMAGE   engine/CLI image to run        (default pulumi-cli-oci:latest)
#   PULUMI_POD_PROJECT_DIR    project dir mounted at /project (default: cwd)
#   PULUMI_POD_STATE_DIR      host dir mounted at /state      (for file:// backends)
#   PULUMI_POD_HOME           host dir mounted as the container's PULUMI_HOME, so
#                             login + stack selection persist across invocations
#                             (a pod-dedicated dir — NOT the host's ~/.pulumi)
# Forwarded into the engine container when set in the environment:
#   PULUMI_BACKEND_URL  PULUMI_CONFIG_PASSPHRASE  PULUMI_ACCESS_TOKEN
#   PULUMI_POD_PROGRAM_IMAGE  PULUMI_POD_PLUGIN_REGISTRY
#
# Usage: pulumi-pod <pulumi args...>
set -euo pipefail

PROJECT_DIR="${PULUMI_POD_PROJECT_DIR:-$PWD}"
ENGINE_IMAGE="${PULUMI_POD_ENGINE_IMAGE:-pulumi-cli-oci:latest}"

POD_ID="$$-${RANDOM}"
NET="pulumi-pod-$POD_ID"
ENGINE_NAME="$NET-engine"
POD_LABEL="com.pulumi.pod=$POD_ID"

cleanup() {
  # The engine container is --rm; this reclaims the network and any provider/
  # program containers the engine started in its netns (labelled, but not removed
  # if the run was interrupted before host.Close()).
  local leftovers
  leftovers="$(docker ps -aq --filter "label=$POD_LABEL" 2>/dev/null || true)"
  [ -n "$leftovers" ] && docker rm -f $leftovers >/dev/null 2>&1 || true
  docker network rm "$NET" >/dev/null 2>&1 || true
}
trap cleanup EXIT

docker network create "$NET" >/dev/null

# Forward selected env vars into the engine container, but only those actually set
# — so the contract stays explicit and the argv stays clean.
fwd=()
for v in PULUMI_BACKEND_URL PULUMI_CONFIG_PASSPHRASE PULUMI_ACCESS_TOKEN \
         PULUMI_POD_PROGRAM_IMAGE PULUMI_POD_PLUGIN_REGISTRY; do
  [ -n "${!v:-}" ] && fwd+=(-e "$v=${!v}")
done

mounts=(-v "$PROJECT_DIR:/project")
[ -n "${PULUMI_POD_STATE_DIR:-}" ] && mounts+=(-v "$PULUMI_POD_STATE_DIR:/state")
# A pod-dedicated PULUMI_HOME, mounted so login + stack selection persist across
# invocations (each is a fresh container, but they share this dir). Set PULUMI_HOME
# explicitly rather than relying on the container's HOME. Use a dedicated dir, not
# the host's ~/.pulumi: the container writes linux/pod state that shouldn't mingle
# with the host CLI's home.
if [ -n "${PULUMI_POD_HOME:-}" ]; then
  mounts+=(-v "$PULUMI_POD_HOME:/pulumi-home" -e "PULUMI_HOME=/pulumi-home")
fi

# Run the command in the engine container (its ENTRYPOINT is `pulumi`). Capture the
# exit code rather than exec'ing, so the EXIT trap still reclaims the pod.
status=0
docker run --rm -i \
  --privileged \
  --network "$NET" \
  --name "$ENGINE_NAME" \
  --hostname "$ENGINE_NAME" \
  --label "$POD_LABEL" \
  -v /var/run/docker.sock:/var/run/docker.sock \
  "${mounts[@]}" \
  -w /project \
  -e PULUMI_POD_MODE=true \
  -e PULUMI_POD_NETWORK="$NET" \
  -e PULUMI_POD_ADVERTISE_HOST="$ENGINE_NAME" \
  -e PULUMI_POD_ID="$POD_ID" \
  "${fwd[@]}" \
  "$ENGINE_IMAGE" \
  "$@" || status=$?
exit $status
