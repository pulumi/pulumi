#!/usr/bin/env bash
#
# pulumi-pod — a `pulumi` stand-in for containerized (pod-mode) execution.
#
# It unconditionally bootstraps a pod and runs the given pulumi command inside the
# engine/CLI container — pulumi-pod *is* the OCI bootstrap, invoked intentionally,
# so there is no project-type sniffing or fall-through to a bare `pulumi`. Use it
# in place of `pulumi` for a containerized project (`pulumi-pod up`, `pulumi-pod
# preview`, `pulumi-pod stack output x`).
#
# It encapsulates the orchestration boilerplate that was previously hand-rolled in
# every smoke test: create a pod network, run the engine container on it with the
# docker socket + project (+ state + PULUMI_HOME) mounted and the PULUMI_POD_*
# contract set, run the command, then tear the pod down. Each invocation is one
# pulumi command in a fresh, ephemeral pod — the "self-contained execution unit"
# the design aims at, and the same shape a remote executor would run.
#
# Cost: every invocation stands up a container + network. For deploy commands
# (up/preview/destroy) that is inherent — they need the engine, providers, and
# program on a network. For read-only commands the network is unused overhead;
# acceptable for this MVP. The eventual local-dev optimization is a *persistent*
# pod session (a long-lived engine the wrapper attaches to, amortizing startup) —
# the design's tier-one inner-loop-latency concern, a separate feature.
#
# State persists across these ephemeral pods through a single mounted dir, with
# sensible defaults so nothing is silently lost. The pod keeps its PULUMI_HOME
# *inside* the mounted workspace (a `.pulumi-pod` dir), and — unless you point
# PULUMI_BACKEND_URL elsewhere — the file backend lives inside that home too. So
# login, stack selection, and stack state all persist together via the one
# workspace mount: a `stack select` sticks for a later `up` with no `--stack`. (The
# file backend's location follows the login URL, not PULUMI_HOME, so we point it
# explicitly inside the home rather than relying on them to coincide.)
#
# This is a prototype helper living alongside the smoke tests. The eventual home is
# the CLI itself (or an installed `pulumi-pod` on PATH); the design deliberately
# prefers this wrapper over having the CLI fork itself.
#
# Config via env (all optional):
#   PULUMI_POD_ENGINE_IMAGE     engine/CLI image to run             (default: DEFAULT_ENGINE_IMAGE below)
#   PULUMI_POD_MOUNT_DIR        host dir mounted at /workspace       (default: cwd) — mount a
#                               repo root here when the program reads files from a parent dir
#   PULUMI_POD_PROJECT_SUBPATH  Pulumi.yaml dir relative to the mount (default: the mount root)
#   PULUMI_POD_PLUGIN_REGISTRY  registry the engine pulls provider images from (host[:port]);
#                               unset -> a shared local pull-through proxy is started (below)
#   PULUMI_POD_PROXY_IMAGE      image the proxy runs from  (default: the engine image — the
#                               proxy is that same pulumi-pod image, run with a different entrypoint)
#   PULUMI_POD_PROXY            'auto' (default) starts the proxy when no registry is set; 'off' disables it
#   PULUMI_POD_PROXY_PORT       host port the proxy publishes                        (default: 5005)
# The whole host environment is forwarded into the engine container, minus a
# denylist of host-context vars (PATH/HOME/TMPDIR/…, DOCKER_HOST, and the vars this
# wrapper sets itself). So credentials (AWS_*, GOOGLE_*, …), PULUMI_BACKEND_URL,
# PULUMI_CONFIG_PASSPHRASE, PULUMI_POD_PROGRAM_IMAGE, etc. all forward by default —
# the same way stock Pulumi gives providers the full shell env. The engine then
# projects its environment onto provider containers (same denylist shape).
#
# Usage: pulumi-pod <pulumi args...>
set -euo pipefail

# The published pulumi-pod image — ONE artifact carrying the engine (pulumi), the OCI
# language host, and the provider registry proxy. Set the namespace to wherever
# publish-images.sh pushed it; this default makes the wrapper PULL instead of building.
# Override PULUMI_POD_ENGINE_IMAGE to use a local build or a different registry.
DEFAULT_ENGINE_IMAGE="ghcr.io/pulumi-labs/pulumi-pod:latest"

MOUNT_DIR="${PULUMI_POD_MOUNT_DIR:-$PWD}"
SUBPATH="${PULUMI_POD_PROJECT_SUBPATH:-}"
ENGINE_IMAGE="${PULUMI_POD_ENGINE_IMAGE:-$DEFAULT_ENGINE_IMAGE}"

# The workspace is mounted at /workspace; the project (Pulumi.yaml) is the mount
# root, or a subpath of it when a parent was mounted for shared libraries. The pod
# home — and, by default, the file backend — live inside it as .pulumi-pod, so the
# single mount carries login, stack selection, and stack state together.
WORKDIR="/workspace${SUBPATH:+/$SUBPATH}"
POD_HOME="$WORKDIR/.pulumi-pod"
# Ensure the home exists on the host so the mount + file backend have a target.
mkdir -p "$MOUNT_DIR${SUBPATH:+/$SUBPATH}/.pulumi-pod"

POD_ID="$$-${RANDOM}"
NET="pulumi-pod-$POD_ID"
ENGINE_NAME="$NET-engine"
POD_LABEL="com.pulumi.pod=$POD_ID"

cleanup() {
  # The engine container is --rm; this reclaims the network and any provider/program
  # containers and plugin volumes the engine created in this pod (labelled, but not
  # removed if the run was interrupted before host.Close()).
  local leftovers vols
  leftovers="$(docker ps -aq --filter "label=$POD_LABEL" 2>/dev/null || true)"
  [ -n "$leftovers" ] && docker rm -f $leftovers >/dev/null 2>&1 || true
  vols="$(docker volume ls -q --filter "label=$POD_LABEL" 2>/dev/null || true)"
  [ -n "$vols" ] && docker volume rm -f $vols >/dev/null 2>&1 || true
  docker network rm "$NET" >/dev/null 2>&1 || true
}
trap cleanup EXIT

# Pull the pod image up front, with visible progress. Otherwise its first pull happens
# silently inside the detached, output-suppressed proxy start below and looks like a hang.
if ! docker image inspect "$ENGINE_IMAGE" >/dev/null 2>&1; then
  echo "pulumi-pod: pulling $ENGINE_IMAGE (first run — this can take a minute)…" >&2
  docker pull "$ENGINE_IMAGE" >&2 || true
fi

# Provider images come from an OCI registry the engine pulls from
# (PULUMI_POD_PLUGIN_REGISTRY threads through the container host's provider-image
# resolution). Unless the caller points at their own registry, run a shared, long-lived
# pull-through proxy that synthesizes any released provider image on demand from
# get.pulumi.com — so no provider images need pre-publishing. The proxy is shared infra
# (one per host, not per pod): started on first use and left running (stop it with
# `docker rm -f pulumi-pod-registry-proxy`). It degrades gracefully — if it can't be
# started, the run continues and the engine uses whatever provider images are already
# present locally.
PROXY_MODE="${PULUMI_POD_PROXY:-auto}"
# The proxy runs from the SAME image as the engine (via --entrypoint registry-proxy), so it
# defaults to the engine image; override PULUMI_POD_PROXY_IMAGE only to pin a different one.
PROXY_IMAGE="${PULUMI_POD_PROXY_IMAGE:-$ENGINE_IMAGE}"
PROXY_NAME="pulumi-pod-registry-proxy"
PROXY_PORT="${PULUMI_POD_PROXY_PORT:-5005}"

ensure_registry_proxy() {
  # Reuse a running proxy; otherwise clear any stale one and start fresh. Running the
  # multi-arch proxy image natively, it synthesizes for its own (== the host's) arch,
  # so provider images match the local daemon with no configuration.
  if [ -n "$(docker ps -q --filter "name=^/${PROXY_NAME}$" --filter status=running 2>/dev/null)" ]; then
    return 0
  fi
  docker rm -f "$PROXY_NAME" >/dev/null 2>&1 || true
  echo "pulumi-pod: starting shared provider registry proxy ($PROXY_NAME) on localhost:$PROXY_PORT" >&2
  docker run -d --name "$PROXY_NAME" --label "com.pulumi.pod-proxy=1" \
    --entrypoint registry-proxy -p "$PROXY_PORT:5000" "$PROXY_IMAGE" >/dev/null 2>&1 || return 1
  # Wait for the distribution API to answer (if curl is present; else give it a moment).
  if command -v curl >/dev/null 2>&1; then
    for _ in $(seq 1 30); do
      curl -sf "http://localhost:$PROXY_PORT/v2/" >/dev/null 2>&1 && return 0
      sleep 0.5
    done
    return 1
  fi
  sleep 2
  return 0
}

PLUGIN_REGISTRY="${PULUMI_POD_PLUGIN_REGISTRY:-}"
if [ -z "$PLUGIN_REGISTRY" ] && [ "$PROXY_MODE" != "off" ]; then
  if ensure_registry_proxy; then
    PLUGIN_REGISTRY="localhost:$PROXY_PORT"
  else
    echo "pulumi-pod: provider registry proxy unavailable; the engine will use only locally-present provider images (set PULUMI_POD_PLUGIN_REGISTRY to use a registry directly)" >&2
  fi
fi

docker network create "$NET" >/dev/null

# Forward the whole host environment into the engine container, minus a denylist of
# vars meaningful only in the host's context. This mirrors stock Pulumi, which
# spawns providers as child processes inheriting the full shell env (so credentials
# "just work"), and it is symmetric with the engine -> provider projection (same
# denylist shape): credentials and config flow by default; no var needs naming.
#
# The denylist drops (a) host paths / shell vars the engine image owns its own copy
# of — projecting them would clobber the container or point at host paths that do not
# exist in it (PATH/HOME/PWD/TMPDIR/…, and language paths PYTHONPATH/NODE_PATH that
# would later mislead a provider container the engine projects onto); (b) DOCKER_HOST,
# a host socket path (the socket is bind-mounted at a fixed path); and (c) the vars
# this wrapper sets itself below (PULUMI_HOME and the pod-runtime vars), so the
# wrapper's values win. Best effort: the list grows as we find host vars that mislead
# the pod. (host -> engine is a trust boundary; an allowlist would be the opt-in
# hardened mode — forward-all is the dev default, parity with stock.)
fwd=()
for name in $(compgen -e); do
  case "$name" in
    PATH | HOME | PWD | OLDPWD | TMPDIR | SHLVL | TERM | HOSTNAME | DOCKER_HOST | PYTHONPATH | NODE_PATH) continue ;;
    PULUMI_HOME | PULUMI_POD_MODE | PULUMI_POD_NETWORK | PULUMI_POD_ADVERTISE_HOST | PULUMI_POD_ID | PULUMI_POD_PLUGIN_REGISTRY) continue ;;
  esac
  fwd+=(-e "$name=${!name}")
done
# Default the backend to a file backend inside the pod home, unless the caller
# configured one (a backend URL, or a service access token).
if [ -z "${PULUMI_BACKEND_URL:-}" ] && [ -z "${PULUMI_ACCESS_TOKEN:-}" ]; then
  fwd+=(-e "PULUMI_BACKEND_URL=file://$POD_HOME")
fi
# Point the engine at the resolved provider registry (the local proxy, or the caller's).
if [ -n "$PLUGIN_REGISTRY" ]; then
  fwd+=(-e "PULUMI_POD_PLUGIN_REGISTRY=$PLUGIN_REGISTRY")
fi

# Run the command in the engine container (its ENTRYPOINT is `pulumi`). Capture the
# exit code rather than exec'ing, so the EXIT trap still reclaims the pod. The lone
# bind is the workspace; PULUMI_HOME (and the file backend) sit inside it.
status=0
docker run --rm -i \
  --privileged \
  --network "$NET" \
  --name "$ENGINE_NAME" \
  --hostname "$ENGINE_NAME" \
  --label "$POD_LABEL" \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v "$MOUNT_DIR:/workspace" \
  -w "$WORKDIR" \
  -e PULUMI_HOME="$POD_HOME" \
  -e PULUMI_POD_MODE=true \
  -e PULUMI_POD_NETWORK="$NET" \
  -e PULUMI_POD_ADVERTISE_HOST="$ENGINE_NAME" \
  -e PULUMI_POD_ID="$POD_ID" \
  "${fwd[@]}" \
  "$ENGINE_IMAGE" \
  "$@" || status=$?
exit $status
